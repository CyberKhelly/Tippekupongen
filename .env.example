# Copy this file to .env and fill in your API keys.
# .env is gitignored — never commit it.

# API-Football (fixtures, lineups, standings)
# Get a free key at: https://rapidapi.com/api-sports/api/api-football
# Free tier: 100 requests/day — sufficient for weekly sync
API_FOOTBALL_KEY=

# The Odds API (aggregated bookmaker odds including Pinnacle)
# Get a free key at: https://the-odds-api.com
# Free tier: 500 requests/month — sufficient for weekly sync
ODDS_API_KEY=

# Optional: override the default SQLite database path
# DB_PATH=data/tippekupongen.db
